{
  "name": "nocodb-integrations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:watch": "pnpm -r test:watch",
    "lint": "eslint \"packages/**/src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"packages/**/src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"packages/**/src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"packages/**/src/**/*.{ts,tsx,json,md}\"",
    "fix": "pnpm format && pnpm lint:fix",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^20.17.46",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.26.0",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.5.3",
    "taze": "^19.1.0",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ],
    "overrides": {
      "axios@>=1.0.0 <1.16.0": ">=1.16.0",
      "postcss@<8.5.10": ">=8.5.10",
      "uuid@>=11.0.0 <11.1.1": "^11.1.1",
      "vite@>=6.0.0 <6.4.2": ">=6.4.2",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4"
    }
  }
}
